# Anthropic Claude API (required for AI summaries & campaign angles)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Reddit OAuth App credentials (optional — falls back to public API)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Twitter/X API Bearer Token (optional — trending topics)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Cron schedule (default: 6AM UTC daily)
CRON_SCHEDULE=0 6 * * *

# Server port
PORT=3001

# SQLite database path (relative to server directory)
DB_PATH=./data/news.db

# Client URL for CORS (dev)
CLIENT_URL=http://localhost:3000
